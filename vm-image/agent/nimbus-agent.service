[Unit]
Description=Nimbus Agent (Pydantic-AI)
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/opt/nimbus-agent
Environment=NIMBUS_AGENT_PORT=8100
Environment=NIMBUS_WORKSPACE=/home/workspace
Environment=NIMBUS_AGENT_SOUL_PATH=/opt/nimbus-agent/SOUL.md
Environment=HOME=/home/ubuntu
Environment=PATH=/opt/nimbus-agent/.venv/bin:/usr/bin:/bin
ExecStart=/opt/nimbus-agent/.venv/bin/python -m uvicorn nimbus_agent.main:app --host 0.0.0.0 --port 8100
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
